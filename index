            data-title="Assignment: Charging Station Finder UI"
			data-desc="UI/UX design assignment focused on creating a mobile-first interface for locating EV charging stations. Emphasized usability, filtering options, and responsive layout using modern CSS techniques."
			data-tech="UI/UX Design, CSS Grid, Flexbox"

            data-image="images/portfolio/electricCar1.jpg">
