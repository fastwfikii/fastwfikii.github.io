              Want a modern landing page for an EV product, a charging dashboard UI, or an API-integrated web app?
              Send a message and include your goal + timeline.
            </p>

            <div class="contact__cards" aria-label="Contact methods">
              <div class="mini">
                <p class="mini__label">Email</p>
                <a class="mini__value" href="mailto:afolarinoluwafikayos@sau.edu">afolarinoluwafikayos@sau.edu</a>
              </div>
              <div class="mini">
                <p class="mini__label">Location</p>
                <p class="mini__value">Chicago, IL</p>
              </div>
              <div class="mini">
                <p class="mini__label">GitHub</p>
                <a class="mini__value" href="#" id="githubLink" rel="noopener" target="_blank">Set username in api.js</a>
              </div>
            </div>
          </div>

          <form class="card form" id="contactForm" novalidate>
            <div class="form__row">
              <label class="form__label" for="name">Name</label>
              <input class="form__input" id="name" name="name" type="text" autocomplete="name" required />
              <p class="form__error" id="nameError" aria-live="polite"></p>
            </div>

            <div class="form__row">
              <label class="form__label" for="email">Email</label>
              <input class="form__input" id="email" name="email" type="email" autocomplete="email" required />
              <p class="form__error" id="emailError" aria-live="polite"></p>
            </div>

            <div class="form__row">
              <label class="form__label" for="message">Message</label>
              <textarea class="form__input form__input--textarea" id="message" name="message" rows="5" required></textarea>
              <p class="form__error" id="messageError" aria-live="polite"></p>
            </div>

            <button class="btn btn--primary form__submit" type="submit">Send Message</button>
            <p class="form__success" id="formSuccess" aria-live="polite"></p>
          </form>
        </div>
      </div>
    </section>
